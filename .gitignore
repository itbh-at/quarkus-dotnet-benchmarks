# Build output
target/
bin/obj/
bin/Debug/
bin/Release/

# H2 binary database (SQL export is committed instead)
# Note: leading `**/` makes the pattern match the analysis-scripts/database/
# location, not just a top-level database/ dir.
**/database/*.mv.db
**/database/*.trace.db
**/database/*.lock.db
**/database/*.h2.db

# Generated reports (regenerated from DB on demand)
reports/

# IDE
.idea/
.vscode/
*.iml
.DS_Store

# Maven
.mvn/repository/

# mise
.mise.local.toml
